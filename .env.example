# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Solana RPC
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Helius RPC (recommended for reliable transaction sending - free at https://dev.helius.xyz)
HELIUS_API_KEY=""

# Bags API (required - get from https://dev.bags.fm)
BAGS_API_BASE_URL="https://public-api-v2.bags.fm/api/v1"
BAGS_API_KEY=""

# App identity
NEXT_PUBLIC_BAGSCAN_NAME="BagScan"
# Bubblemaps "demo" only works on local development. Use a real production partner ID on live domains.
NEXT_PUBLIC_BUBBLEMAPS_PARTNER_ID="demo"

# BagScan monetization / partner setup (optional)
BAGSCAN_PARTNER_WALLET=""
BAGSCAN_PARTNER_CONFIG=""
BAGSCAN_ADMIN_SECRET="change-me"

# Agent integration (OpenClaw / SolClaw)
# Used by /api/agent/v1/* endpoints via x-agent-key or Authorization: Bearer
BAGSCAN_AGENT_API_KEY="change-me-agent-key"

# Talk To Bags via OpenClaw (optional)
# If configured, /api/talk will use OpenClaw first and fall back to the local official-BAGS engine on error.
# OPENCLAW_BASE_URL can be either:
# - an HTTP(S) OpenAI-compatible endpoint base, or
# - a WS(S) gateway base such as wss://agent-...up.railway.app
#   In that case BagScan will automatically derive https://.../v1/chat/completions.
OPENCLAW_BASE_URL=""
OPENCLAW_GATEWAY_TOKEN=""
OPENCLAW_MODEL="openclaw/main"
OPENCLAW_AGENT_ID="main"

# Optional defaults
NEXT_PUBLIC_DEFAULT_SLIPPAGE_BPS="100"
NEXT_PUBLIC_PLATFORM_FEE_BPS="0"

# Xquik API for X/Twitter data (optional - get from https://xquik.com)
XQUIK_API_KEY=""

# Alerts / Notifications
ALERTS_SESSION_SECRET="change-me-long-random-string"
ALERTS_CRON_SECRET="change-me-cron-secret"
# Keep /api/alerts/cron configured as an external backup if your host supports it.
# Internal runtime and external cron can safely coexist because BagScan uses a DB advisory lock.
ENABLE_INTERNAL_ALERTS_RUNTIME="true"
ALERTS_RUNTIME_INTERVAL_MS="60000"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=""
