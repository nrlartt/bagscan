generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AlertKind {
  alpha_hot
  alpha_critical
  portfolio_profit
  portfolio_drawdown
  fee_claim
  system
}

enum AlertSeverity {
  info
  hot
  critical
}

model TokenSnapshot {
  id             String   @id @default(cuid())
  tokenMint      String
  poolAddress    String?
  name           String?
  symbol         String?
  image          String?
  creatorWallet  String?
  creatorDisplay String?
  provider       String?
  providerUser   String?
  fdvUsd         Float?
  priceUsd       Float?
  liquidityUsd   Float?
  volume24hUsd   Float?
  lifetimeFees   Float?
  claimCount     Int?
  claimVolume    Float?
  rawJson        String?
  capturedAt     DateTime @default(now())

  @@index([tokenMint])
  @@index([capturedAt])
}

model TokenRegistry {
  tokenMint          String   @id
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @updatedAt
  poolAddress        String?
  name               String?
  symbol             String?
  image              String?
  description        String?
  website            String?
  twitter            String?
  telegram           String?
  creatorWallet      String?
  creatorDisplay     String?
  provider           String?
  providerUser       String?
  launchSource       String?
  latestPriceUsd     Float?
  latestFdvUsd       Float?
  latestLiquidityUsd Float?
  latestLifetimeFees Float?
  latestClaimCount   Int?
  isActive           Boolean  @default(true)
  rawJson            String?
}

model LaunchDraft {
  id              String   @id @default(cuid())
  walletAddress   String?
  name            String
  symbol          String
  description     String
  imageUrl        String?
  website         String?
  twitter         String?
  telegram        String?
  tokenMint       String?
  tokenMetadata   String?
  feeShareConfig  String?
  partnerIncluded Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model PartnerSnapshot {
  id            String   @id @default(cuid())
  partnerWallet String
  claimedFees   Float?
  unclaimedFees Float?
  rawJson       String?
  capturedAt    DateTime @default(now())
}

model AlertPreference {
  id                       String              @id @default(cuid())
  walletAddress            String              @unique
  inAppEnabled             Boolean             @default(true)
  browserPushEnabled       Boolean             @default(false)
  telegramEnabled          Boolean             @default(false)
  alphaHotEnabled          Boolean             @default(true)
  alphaCriticalEnabled     Boolean             @default(true)
  portfolioProfitEnabled   Boolean             @default(true)
  portfolioDrawdownEnabled Boolean             @default(true)
  feesEnabled              Boolean             @default(true)
  profitThresholdPercent   Float               @default(25)
  drawdownThresholdPercent Float               @default(-15)
  claimableFeesThresholdSol Float              @default(0.25)
  telegramChatId           String?
  lastEvaluatedAt          DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  notifications            AlertNotification[]
  pushSubscriptions        PushSubscription[]

  @@index([lastEvaluatedAt])
}

model TelegramBroadcastTarget {
  id                 String   @id @default(cuid())
  chatId             String   @unique
  chatType           String
  title              String?
  username           String?
  isActive           Boolean  @default(true)
  trendingEnabled    Boolean  @default(true)
  launchesEnabled    Boolean  @default(true)
  digestEnabled      Boolean  @default(true)
  lastTrendingSentAt DateTime?
  lastLaunchesSentAt DateTime?
  lastDigestSentAt   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
}

model TelegramBotState {
  key          String   @id
  lastUpdateId Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model PushSubscription {
  id             String          @id @default(cuid())
  walletAddress  String
  endpoint       String          @unique
  p256dh         String
  auth           String
  expirationTime String?
  userAgent      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  preference     AlertPreference @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@index([walletAddress])
}

model AlertNotification {
  id                 String          @id @default(cuid())
  walletAddress      String
  kind               AlertKind
  severity           AlertSeverity
  title              String
  message            String
  eventKey           String
  tokenMint          String?
  actionUrl          String?
  imageUrl           String?
  readAt             DateTime?
  deliveredPushAt    DateTime?
  deliveredTelegramAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  preference         AlertPreference @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([walletAddress, eventKey])
  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([walletAddress, readAt])
}
